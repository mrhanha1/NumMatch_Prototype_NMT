# This .gitignore file should be placed at the root of your Unity project directory

# Unity
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log
/[Mm]emoryCaptures/
/[Rr]ecordings/
/.utmp/

# Unity Crash Reports
CrashDumps/
sysinfo.txt

# Builds & Exports
*.apk
*.aab
*.ipa
*.app
*.unitypackage
ExportedObj/

# Autogenerated files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Visual Studio / Rider / JetBrains
.vs/
.idea/
[Rr]ider/
*.sln.*
/[Aa]ssets/Plugins/Editor/JetBrains*

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# DOTween
DOTween/
DOTweenPro/
DOTweenTimeline/

# VContainer & Plugins
[Vv]Container/
Plugins/**/*.meta

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa*
/ServerData/

# Asset Store & Cache
/[Aa]ssets/AssetStoreTools*
Cache/

# Profiling & Performance
Profiler/
*.prof

# Logs & Temporary
*.log*
/Logs/

# Custom Project Specific
/Assets/_Project/Art/Imported/*
/Assets/_Project/Scenes/*.unity.meta

# Keep important files
!**/.gitkeep
!.gitignore

# OS generated files
*.orig
*.rej